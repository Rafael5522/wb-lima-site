# Configurações da Aplicação
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=sua-chave-secreta-super-segura-mude-em-producao

# Database
# Para desenvolvimento use SQLite (padrão)
# Para produção, pode usar PostgreSQL no Render
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Email (para envio automático de confirmação)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app
MAIL_DEFAULT_SENDER=contato@wblima.com.br

# Admin
ADMIN_PASSWORD=admin123

# CORS
CORS_ORIGINS=*

# Server Port
PORT=5000
